{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Information",  // ✅ 认证日志
      "Microsoft.AspNetCore.Authorization": "Debug"   // ✅ 授权日志
    }
  },
  "AllowedHosts": "*",
  "Consul": {
    "ServiceUrl": "http://localhost:5050",
    "Environment": "dev",
    "ServiceName": "blog",
    "Mappings": {
      "MySQLConnection": "ConnectionStrings:DefaultConnection"
    }
  },
  "Jwt": {
    "SecretKey": "RiverLi_Blog_Very_Secret_Key_Must_Be_Long_Enough_32_Chars",
    "Issuer": "RiverBlog.Identity",
    "Audience": "RiverBlog.Clients",
    "ExpiryMinutes": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=192.168.16.11;Port=3306;Database=riverli_blog;Uid=root;Pwd=River20260203;AllowPublicKeyRetrieval=True;SslMode=Preferred;"
  },
  "blog_route": {
  "ClusterId": "blog_service",
  "Match": {
    "Path": "/api/v1/blog/{**remainder}"
  },
  "Transforms": [
    { "PathRemovePrefix": "/api/v1/blog" },
    { "X-Forwarded": "Set" },
    // 关键：必须确保 Authorization 头不被网关剥离
    { "RequestHeader": "Authorization", "Set": "{header:Authorization}" }
  ],
    // 🌟 新增：阿里云 OSS 配置节点
    "AliyunOSS": {
      "Endpoint": "https://oss-cn-hangzhou.aliyuncs.com",
      "AccessKeyId": "LTAI5tXXXXXX你的AccessKeyID",
      "AccessKeySecret": "YourAccessKeySecretxxxxxxxx",
      "BucketName": "riverli-blog",
      "CustomDomain": "https://media.riverli.blog" // 可选：如果您配置了 CDN 或自定义域名，留空则使用 OSS 默认域名
    },
    "Services": {
      "IdentityUrl": "http://identity-service:80"
    }
  }
}
