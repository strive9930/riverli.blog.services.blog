{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Information",  // ✅ 认证日志
      "Microsoft.AspNetCore.Authorization": "Debug"   // ✅ 授权日志
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "RiverLi_Blog_Very_Secret_Key_Must_Be_Long_Enough_32_Chars",
    "Issuer": "RiverBlog.Identity",
    "Audience": "RiverBlog.Clients",
    "ExpiryMinutes": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=riverli_blog;Uid=root;Pwd=River20260203;AllowPublicKeyRetrieval=True;SslMode=Preferred;"
  },
  "blog_route": {
  "ClusterId": "blog_service",
  "Match": {
    "Path": "/api/v1/blog/{**remainder}"
  },
  "Transforms": [
    { "PathRemovePrefix": "/api/v1/blog" },
    { "X-Forwarded": "Set" },
    // 关键：必须确保 Authorization 头不被网关剥离
    { "RequestHeader": "Authorization", "Set": "{header:Authorization}" }
  ]
}
}
